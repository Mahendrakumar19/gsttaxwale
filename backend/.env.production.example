# ==========================
# HOSTINGER PRODUCTION SETUP
# ==========================
# Copy this file and rename to .env.local
# Fill in your production values

# ==========================
# DATABASE SETUP (Production)
# ==========================
# Option 1: PostgreSQL (Recommended for production)
# DATABASE_PROVIDER=postgresql
# DATABASE_URL=postgresql://username:password@hostname:5432/gsttaxwale

# Option 2: MySQL
DATABASE_PROVIDER=mysql
DATABASE_URL=mysql://u963801592_gsttaxwale_user:gsttaxwale%40NG2026@localhost:3306/u963801592_gsttaxwale

# Option 3: SQLite (Not recommended for production)
# DATABASE_PROVIDER=sqlite
# DATABASE_URL=file:./prod.db

# ==========================
# SERVER CONFIGURATION
# ==========================
NODE_ENV=production
PORT=5000

# ==========================
# JWT & SECURITY
# ==========================
JWT_SECRET=your-secure-random-jwt-secret-here-generate-a-strong-one
JWT_EXPIRY=7d

# ==========================
# FRONTEND CONFIGURATION
# ==========================
NEXT_PUBLIC_API_URL=https://gsttaxwale.com/api
FRONTEND_URL=https://gsttaxwale.com

# ==========================
# EMAIL CONFIGURATION (Optional)
# # ==========================
# SMTP_HOST=your-smtp-host
# SMTP_PORT=587
# SMTP_USER=your-email
# SMTP_PASSWORD=your-email-password
# SMTP_FROM=noreply@gsttaxwale.com

# ==========================
# AWS S3 (Optional - for file uploads)
# # ==========================
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# AWS_S3_BUCKET=your-bucket-name

# ==========================
# LOGGING
# ==========================
LOG_LEVEL=info
