generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x", "linux-musl", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                   Int           @id @default(autoincrement())
  email                String        @unique
  password             String
  name                 String?
  pan                  String?       @unique(map: "pan") @db.VarChar(50)
  phone                String?
  role                 String        @default("user")
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  active               Boolean       @default(true)
  avatar               String?
  deletedAt            DateTime?
  dateOfBirth          DateTime?     @db.DateTime(0)
  gender               String?       @db.VarChar(10)
  address              String?       @db.Text
  city                 String?       @db.VarChar(100)
  state                String?       @db.VarChar(100)
  pincode              String?       @db.VarChar(10)
  reference_number     String?       @unique(map: "reference_number") @db.VarChar(255)
  referral_code        String?       @unique(map: "referral_code") @db.VarChar(255)
  created_by_admin     Boolean?      @default(false)
  points_wallet        Int?          @default(0)
  status               String?       @default("active") @db.VarChar(20)
  emailVerified        Boolean?      @default(false)
  resetToken           String?       @unique(map: "resetToken") @db.VarChar(255)
  resetTokenExpires    DateTime?     @db.DateTime(0)
  lastPasswordChange   DateTime?     @db.DateTime(0)
  walletId             String?       @unique(map: "walletId") @db.VarChar(255)
  referralCodeId       String?       @unique(map: "referralCodeId") @db.VarChar(255)
  preferEmailReminders Boolean?      @default(true)
  preferredFilingType  String?       @db.VarChar(50)
  aadhaar              String?       @unique(map: "aadhaar") @db.VarChar(50)
  firstName            String?       @db.VarChar(100)
  middleName           String?       @db.VarChar(100)
  lastName             String?       @db.VarChar(100)
  fatherName           String?       @db.VarChar(255)
  doorNo               String?       @db.VarChar(50)
  buildingName         String?       @db.VarChar(255)
  street               String?       @db.VarChar(255)
  area                 String?       @db.VarChar(255)
  country              String?       @default("India") @db.VarChar(100)
  bankDetails          String?       @db.LongText
  filingStatus         String        @default("Under Review")
  documents            Document[]
  orders               Order[]
  subscription         Subscription?

  @@index([pan], map: "idx_pan")
}

model Service {
  id               Int      @id @default(autoincrement())
  slug             String   @unique
  description      String?  @db.LongText
  price            Float?
  features         String?  @db.LongText
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  active           Boolean  @default(true)
  category         String?
  color            String?
  discountPrice    Float?
  duration         String?
  featured         Boolean  @default(false)
  icon             String?
  name             String?  @unique
  position         Int      @default(999)
  requirements     String?  @db.LongText
  shortDescription String?
  turnaroundDays   Int?
  orders           Order[]
}

model Order {
  id             Int        @id @default(autoincrement())
  serviceId      Int
  amount         Float
  status         String     @default("pending")
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  completedAt    DateTime?
  discountAmount Float?     @default(0)
  finalAmount    Float
  notes          String?    @db.LongText
  orderNo        String     @unique
  paymentDate    DateTime?
  paymentId      String?
  paymentMethod  String?
  paymentStatus  String     @default("unpaid")
  uploadedFiles  Int?       @default(0)
  userId         Int
  documents      Document[]
  service        Service    @relation(fields: [serviceId], references: [id])
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([serviceId])
  @@index([userId], map: "Order_userId_fkey")
}

model Document {
  id            Int       @id @default(autoincrement())
  userId        Int
  fileUrl       String
  fileSize      Int?
  uploadedAt    DateTime  @default(now())
  deletedAt     DateTime?
  documentType  String?
  filename      String
  mimeType      String?
  notes         String?
  orderId       Int?
  originalName  String?
  uploadedBy    String
  category      String?   @default("Others")
  financialYear String?
  visible       Boolean   @default(true)
  order         Order?    @relation(fields: [orderId], references: [id])
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([orderId], map: "Document_orderId_fkey")
  @@index([userId])
}

model Subscription {
  id        Int       @id @default(autoincrement())
  userId    Int       @unique
  planName  String
  amount    Float
  startDate DateTime  @default(now())
  endDate   DateTime?
  autoRenew Boolean   @default(true)
  status    String    @default("active")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Contact {
  id        Int       @id @default(autoincrement())
  name      String
  email     String
  phone     String?
  subject   String
  message   String    @db.LongText
  status    String    @default("unread")
  replied   Boolean   @default(false)
  repliedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([email])
}

model Referral {
  id               Int       @id @default(autoincrement())
  refereeEmail     String
  commissionAmount Float?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  activatedAt      DateTime?
  completedAt      DateTime?
  referralCode     String    @unique
  referrerEmail    String
  status           String    @default("pending")

  @@unique([referrerEmail, refereeEmail])
  @@index([referralCode])
}

model AdminLog {
  id         Int      @id @default(autoincrement())
  adminEmail String
  action     String
  entityType String
  entityId   Int?
  changes    String?  @db.LongText
  ipAddress  String?
  userAgent  String?  @db.LongText
  createdAt  DateTime @default(now())

  @@index([adminEmail])
  @@index([createdAt])
}

model EmailLog {
  id        Int      @id @default(autoincrement())
  to        String
  subject   String
  type      String
  status    String   @default("sent")
  errorMsg  String?
  sentAt    DateTime @default(now())
  createdAt DateTime @default(now())

  @@index([to])
  @@index([sentAt])
}

model Location {
  id        Int       @id @default(autoincrement())
  name      String
  address   String    @db.LongText
  city      String?
  state     String?
  pincode   String?   @db.VarChar(50)
  email     String?
  phone     String?
  mapUrl    String?   @db.LongText
  active    Boolean?  @default(true)
  createdAt DateTime? @default(now())
  updatedAt DateTime?
}

model otp_codes {
  id         Int       @id @default(autoincrement())
  email      String    @db.VarChar(255)
  phone      String    @db.VarChar(20)
  code       String    @db.VarChar(10)
  expires_at DateTime  @db.DateTime(0)
  verified   Boolean?  @default(false)
  created_at DateTime? @default(now()) @db.DateTime(0)

  @@unique([email, phone], map: "email_phone")
}
