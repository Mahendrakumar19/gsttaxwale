################################################################################
# TAX PLATFORM - NEXT.JS MONOLITH ENVIRONMENT VARIABLES
################################################################################
# Copy this file to .env.local and fill in your actual values
# DO NOT commit .env.local to Git (it's in .gitignore)

################################################################################
# SERVER CONFIGURATION
################################################################################
NODE_ENV=development
PORT=3000

################################################################################
# DATABASE (MySQL via Prisma)
################################################################################
# Format: mysql://user:password@host:port/database
# Local development example:
DATABASE_URL="mysql://root:password@localhost:3306/tax_platform"

# For Hostinger MySQL: Get from hPanel > MySQL Databases
# DATABASE_URL="mysql://dbuser:dbpass@mysql123.hostinger.com:3306/dbname"

################################################################################
# AUTHENTICATION
################################################################################
# Generate with: openssl rand -hex 32
JWT_SECRET="your-32-character-random-secret-key-change-this-in-production"

# For Next.js Auth (if using in future)
NEXTAUTH_SECRET="generate-another-random-32-char-string"
NEXTAUTH_URL="http://localhost:3000"

################################################################################
# API ENDPOINTS (Frontend calls these routes)
################################################################################
# For local development: http://localhost:3000
# For production Hostinger: https://yourdomain.com
NEXT_PUBLIC_API_URL="http://localhost:3000"

################################################################################
# EMAIL / SMTP (For sending emails)
################################################################################
# Gmail example (enable App Passwords in Google Account)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-google-app-password"
SMTP_FROM_EMAIL="support@yourdomain.com"
SMTP_FROM_NAME="Tax Platform Support"

# Alternative: Hostinger Email
# Get SMTP credentials from hPanel > Email > Your Email Account
# SMTP_HOST="mail.yourdomain.com"
# SMTP_PORT="465"
# SMTP_USER="support@yourdomain.com"
# SMTP_PASSWORD="your-email-password"

################################################################################
# PAYMENT GATEWAY - RAZORPAY
################################################################################
# Get from https://dashboard.razorpay.com
# Test mode: rzp_test_*
# Live mode: rzp_live_*
NEXT_PUBLIC_RAZORPAY_KEY="rzp_test_xxxxxxxxxxxxxx"
RAZORPAY_SECRET="xxxxxxxxxxxxxxxxxxxxxxxx"

# Webhook for payment notifications
RAZORPAY_WEBHOOK_SECRET="whsec_xxxxxxxxxxxxx"

################################################################################
# FILE UPLOADS - AWS S3 (Optional)
################################################################################
# For storing documents, invoices, tax returns, etc.
AWS_ACCESS_KEY_ID="AKIAIOSFODNN7EXAMPLE"
AWS_SECRET_ACCESS_KEY="wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY"
AWS_S3_BUCKET="tax-platform-documents"
AWS_S3_REGION="us-east-1"

# Alternative: Local file uploads (simpler for testing)
# UPLOAD_DIR="./public/uploads"
# MAX_FILE_SIZE="5242880"  # 5MB in bytes

################################################################################
# ADMIN SETUP (For initial creation)
################################################################################
ADMIN_EMAIL="admin@yourdomain.com"
ADMIN_PASSWORD="change-this-in-production"
ADMIN_NAME="Admin User"

################################################################################
# LOGGING
################################################################################
LOG_LEVEL="info"  # debug, info, warn, error
LOG_DIR="./logs"

################################################################################
# FEATURE FLAGS
################################################################################
ENABLE_REFERRAL_PROGRAM="true"
ENABLE_CHAT_SUPPORT="true"
ENABLE_WHATSAPP_INTEGRATION="false"
ENABLE_PAYMENT="true"

################################################################################
# THIRD-PARTY INTEGRATIONS (Optional)
################################################################################

# WhatsApp Business (optional)
WHATSAPP_BUSINESS_PHONE_ID=""
WHATSAPP_BUSINESS_ACCESS_TOKEN=""

# Telegram Bot (optional)
TELEGRAM_BOT_TOKEN=""

# Google OAuth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

################################################################################
# DATABASE BACKUP (Optional)
################################################################################
BACKUP_ENABLED="true"
BACKUP_SCHEDULE="0 2 * * *"    # 2 AM daily
BACKUP_RETENTION_DAYS="30"

################################################################################
# PRODUCTION EXAMPLE (Hostinger Deployment)
################################################################################
# NODE_ENV=production
# PORT=3000
# DATABASE_URL="mysql://dbuser:dbpass@mysql123.hostinger.com:3306/taxdb"
# JWT_SECRET="generate-a-new-random-32-char-string-for-production"
# NEXTAUTH_URL="https://yourdomain.com"
# NEXT_PUBLIC_API_URL="https://yourdomain.com"
# SMTP_HOST="mail.yourdomain.com"
# SMTP_USER="support@yourdomain.com"
# SMTP_PASSWORD="your-email-password"
# NEXT_PUBLIC_RAZORPAY_KEY="rzp_live_xxxxxxxxxxxxx"
# RAZORPAY_SECRET="xxxxxxxxxxxxxxxxxxxxx"

################################################################################
# NOTES
################################################################################
# - NEVER commit .env.local to Git (it's in .gitignore)
# - For Hostinger: Add variables in hPanel > Environment Variables
# - Use .env.example (without secrets) for sharing with team
# - All NEXT_PUBLIC_* variables are visible in frontend (don't put secrets!)
# - Regenerate JWT_SECRET for each environment (dev, staging, prod)
# - Keep RAZORPAY_SECRET, database password, and SMTP_PASSWORD secure
