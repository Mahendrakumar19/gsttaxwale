{
  "name": "tax-platform-unified",
  "version": "1.0.0",
  "description": "Professional GST & Income Tax Filing Platform - Unified Frontend + Backend",
  "private": true,
  "type": "commonjs",
  "main": "server.js",
  "homepage": "https://gsttaxwale.com",
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "scripts": {
    "dev": "node server.js",
    "start": "node server.js",
    "build": "npx prisma generate && cd frontend && npm run build && cd ..",
    "setup-db": "node backend/scripts/setup_db.js",
    "test-login": "node backend/scripts/test_login.js",
    "lint": "next lint",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "seed": "node prisma/seed.js",
    "test": "echo 'Tests not configured'",
    "format": "prettier --write \"app/**/*.{js,jsx,ts,tsx}\" \"lib/**/*.{js,ts}\" \"prisma/**/*.ts\""
  },
  "dependencies": {
    "@prisma/client": "^4.16.2",
    "aws-sdk": "^2.1559.0",
    "axios": "^1.7.2",
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^8.3.2",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.376.0",
    "morgan": "^1.10.1",
    "multer": "^1.4.4",
    "mysql2": "^3.20.0",
    "next": "^14.2.35",
    "nodemailer": "^6.9.7",
    "razorpay": "^2.9.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "redis": "^4.5.1",
    "socket.io": "^4.5.4",
    "socket.io-client": "^4.5.4",
    "sonner": "^1.5.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/node": "^20.10.6",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.2",
    "postcss": "^8.4.38",
    "prisma": "^4.16.2",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.4.5"
  }
}
